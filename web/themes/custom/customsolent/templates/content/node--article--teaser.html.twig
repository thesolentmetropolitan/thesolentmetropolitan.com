{#
/**
 * @file
 * Theme override for an Article node in the teaser view mode.
 *
 * Whole-card clickable: <a> wraps <article>. Horizontal layout —
 * image on the left, text (title / standfirst / date) on the right.
 * When no image is present, the text fills the full row.
 */
#}
{%
  set classes = [
    'node',
    'node--type-' ~ node.bundle|clean_class,
    node.isPromoted() ? 'node--promoted',
    node.isSticky() ? 'node--sticky',
    not node.isPublished() ? 'node--unpublished',
    view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
    'slnt-article-teaser',
    content.field_image|render|striptags|trim ? 'slnt-article-teaser--has-image' : 'slnt-article-teaser--no-image',
  ]
%}

<a href="{{ url }}" class="slnt-article-teaser-link">
  <article{{ attributes.addClass(classes) }}>

    {% if content.field_image|render|striptags|trim %}
      <div class="slnt-article-teaser__image">
        {{ content.field_image }}
      </div>
    {% endif %}

    <div class="slnt-article-teaser__text">
      <h2 class="slnt-article-teaser__title">{{ label }}</h2>

      {% if content.field_standfirst|render|striptags|trim %}
        <p class="slnt-article-teaser__standfirst">{{ content.field_standfirst }}</p>
      {% endif %}

      <time class="slnt-article-teaser__date" datetime="{{ node.getCreatedTime()|date('Y-m-d') }}">
        {{ node.getCreatedTime()|date('j F Y') }}
      </time>
    </div>

  </article>
</a>
