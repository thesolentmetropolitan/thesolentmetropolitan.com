</form>

#}

{% if 'search-form' in attributes.storage["class"][0] %}

  <div id="search-page-form-container" class=""> 
    <h2>Searching for:</h2>
    <div{{ attributes.addClass(classes) }}>
      {{ title_prefix }}
      {% if label %}
        <h2{{ title_attributes }}>{{ label }}</h2>
      {% endif %}
      {{ title_suffix }}
      {% block content %}
        <form action="/search/node" method="get" id="search-page-block-form" accept-charset="UTF-8" data-once="form-updated" data-drupal-form-fields="edit-keys">
          <input id="search-page-search-input-field" type="text" name="keys" placeholder="Search...">
            <button class="search-menu-item-icon" type="submit" title="Submit">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" role="presentation" focusable="false">
                <circle cx="10.5" cy="10.5" r="7.5"/>
                <line x1="21" y1="21" x2="15.8" y2="15.8"/>
              </svg>
            </button>
        </form>
      {% endblock %}
    </div>
  </div>
{% else %}
<form{{ attributes }}>
  {{ children }}
</form>
{% endif %}



