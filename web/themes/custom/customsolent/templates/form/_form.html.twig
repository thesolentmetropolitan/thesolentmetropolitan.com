{#
/**
 * @file
 * Theme override for a 'form' element.
 *
 * Available variables
 * - attributes: A list of HTML attributes for the wrapper element.
 * - children: The child elements of the form.
 *
 * @see template_preprocess_form()
 */

   {{ dd( attributes ) }}
  {{ dd( attributes.storage["class"][0] ) }} == "search-form"
  {{ dd( children ) }}


   {{ dd( attributes ) }}
  {{ dd( children ) }}

  {% if 'search-form' in attributes.storage["class"][0] %}
  <div id="search-form-container" class=""> 
    <div{{ attributes.addClass(classes) }}>
      {{ title_prefix }}
      {% if label %}
        <h2{{ title_attributes }}>{{ label }}</h2>
      {% endif %}
      {{ title_suffix }}
      {% block content %}
        <form action="/search/node" method="get" id="search-block-form" accept-charset="UTF-8" data-once="form-updated" data-drupal-form-fields="edit-keys">
          <input type="text" name="keys" placeholder="Search...">
          <button class="search-menu-item-icon" type="submit" title="Submit">
            <svg class="icon" aria-hidden="true" role="presentation" focusable="false"> 
              <use xlink:href="/themes/custom/eela/search-magnifying-glass.svg"></use>
            </svg>
          </button>
        </form>
      {% endblock %}
    </div>
  </div>
{% else %}
<form{{ attributes }}>
  {{ children }}
</form>
{% endif %}


<form{{ attributes }}>
